# ── Personal data — never upload these ───────────────────────────────────────
.gitignore             # this file itself
projects.json          # your personal folder paths
memory/                # ChromaDB vector store (your private conversations)
context_stash.txt      # old rolling summary (legacy)

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
